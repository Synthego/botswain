# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=botswain.settings.local
DEBUG=True

# Database Settings
POSTGRES_DB=botswain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Settings
REDIS_URL=redis://redis:6379/1

# Botswain Settings
# LLM Provider: 'bedrock' or 'claude_cli'
BOTSWAIN_LLM_PROVIDER=bedrock

# AWS Bedrock Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MAX_INTENT_TOKENS=500
BEDROCK_MAX_RESPONSE_TOKENS=1000
AWS_REGION=us-west-2
BEDROCK_TIMEOUT=30.0

# Production Database Credentials (READ-ONLY ACCESS)
# Required for: botswain.settings.barb_prod_replica and botswain.settings.multi_source
# NEVER commit these values to git - keep them in .env only
BARB_READONLY_PASSWORD=your_barb_readonly_password_here
BUCKANEER_READONLY_PASSWORD=your_buckaneer_readonly_password_here
BUCKANEER_PASSWORD=your_buckaneer_password_here
