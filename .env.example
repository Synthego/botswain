# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=botswain.settings.local
DEBUG=True

# Database Settings
POSTGRES_DB=botswain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Settings
REDIS_URL=redis://redis:6379/1

# Botswain Settings
BOTSWAIN_LLM_PROVIDER=claude_cli
